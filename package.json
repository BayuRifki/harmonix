{
  "name": "harmonix",
  "version": "0.1.0",
  "description": "A unified cross-source music player for desktop — Spotify, YouTube Music, and local files in one place.",
  "main": "dist-electron/main/index.js",
  "type": "module",
  "author": "Harmonix Contributors",
  "license": "MIT",
  "homepage": "https://github.com/your-username/harmonix",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/harmonix.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/harmonix/issues"
  },
  "keywords": [
    "music",
    "player",
    "spotify",
    "youtube-music",
    "electron",
    "react",
    "typescript"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "icons": "node scripts/generate-icons.mjs && node scripts/generate-ico.mjs",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "typecheck": "tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.main.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "dist:all": "electron-vite build && electron-builder -mw",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "electron-store": "^10.0.0",
    "music-metadata": "^10.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "sql.js": "^1.12.0",
    "youtubei.js": "^17.0.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/spotify-web-playback-sdk": "^0.1.19",
    "@types/sql.js": "^1.4.11",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.8.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "husky": "^9.1.6",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
