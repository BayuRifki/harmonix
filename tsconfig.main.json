{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "node",
    "module": "CommonJS",
    "target": "ES2022",
    "lib": ["ES2022"],
    "jsx": "preserve",
    "types": ["node"],
    "noEmit": true,
    "composite": false
  },
  "include": [
    "electron/**/*.ts"
  ],
  "exclude": [
    "src/**/*",
    "node_modules",
    "dist",
    "dist-electron"
  ]
}
