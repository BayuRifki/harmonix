# Harmonix — Environment Variables
# Copy this file to `.env` and fill in your values.
# NEVER commit your real `.env` file.

# ─────────────────────────────────────────────────────────────
# Spotify (Phase 3)
# ─────────────────────────────────────────────────────────────
# Get credentials at: https://developer.spotify.com/dashboard/
# 1. Create an app
# 2. Add this redirect URI to "App settings":
#    http://127.0.0.1:8888/callback
# 3. Note the "Client ID" (not Client Secret — we use PKCE flow)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ─────────────────────────────────────────────────────────────
# YouTube Music (Phase 4 — OPTIONAL)
# ─────────────────────────────────────────────────────────────
# yt-dlp will be used for stream resolution.
# You can either:
#   (a) bundle it in `resources/yt-dlp/` (recommended for offline distribution)
#   (b) let the app download it on first launch
# If (b), set the download URL (defaults to GitHub releases):
# YT_DLP_DOWNLOAD_URL=https://github.com/yt-dlp/yt-dlp/releases/latest/download

# ─────────────────────────────────────────────────────────────
# Local Library (Phase 1)
# ─────────────────────────────────────────────────────────────
# Default folder to scan on first launch (user-configurable in settings).
# LIBRARY_DEFAULT_PATH=/path/to/your/music

# ─────────────────────────────────────────────────────────────
# Jamendo (Phase 8 — OPTIONAL)
# ─────────────────────────────────────────────────────────────
# Get a free Client ID at: https://developer.jamendo.com/v3.0
# Without this, the public test id (709fa152) is used — fine for development.
# JAMENDO_CLIENT_ID=your_jamendo_client_id

# ─────────────────────────────────────────────────────────────
# Audius (Phase 8 — OPTIONAL)
# ─────────────────────────────────────────────────────────────
# Audius is decentralized. Override the discovery node if audius.co is unavailable.
# AUDIUS_HOST=https://audius.co

# ─────────────────────────────────────────────────────────────
# SoundCloud (Phase 8 — OPTIONAL)
# ─────────────────────────────────────────────────────────────
# SoundCloud's public API requires a client_id from a registered Artist Pro app.
# New developer registration is closed, but existing clients can still use the API.
# https://developers.soundcloud.com/docs/api/guide
# SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id
# SOUNDCLOUD_CLIENT_SECRET=your_soundcloud_client_secret

# ─────────────────────────────────────────────────────────────
# Development
# ─────────────────────────────────────────────────────────────
# NODE_ENV=development
# ELECTRON_ENABLE_LOGGING=true
